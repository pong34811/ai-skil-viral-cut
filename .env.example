GROQ_API_KEY=your_key_here

# Optional:
# WHISPER_LANGUAGE=th        # language hint for Whisper (default: auto)
# TEMP_DIR=temp              # temp directory for audio chunks (default: system temp)
# FFMPEG_PATH=ffmpeg         # ffmpeg executable path (default: ffmpeg)
# EXPORT_SORT_BY=score       # sort cuts by score (default: score, desc)
